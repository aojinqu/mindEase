<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.MindEase.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:textSize">31sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.MindEase.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.MindEase.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">-0.005</item>
    </style>

    <style name="TextAppearance.MindEase.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.MindEase.Supporting" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.MindEase.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.MindEase.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.MindEase.Card.Highlight" parent="Widget.MindEase.Card">
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
    </style>

    <style name="Widget.MindEase.Card.Warm" parent="Widget.MindEase.Card">
        <item name="cardBackgroundColor">?attr/colorSecondaryContainer</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
    </style>

    <style name="Widget.MindEase.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="rippleColor">?attr/colorPrimaryContainer</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.MindEase.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.MindEase.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.MindEase.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxBackgroundColor">?attr/colorSurface</item>
        <item name="boxStrokeColor">?attr/colorOutlineVariant</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MindEase.Medium</item>
    </style>

    <style name="Widget.MindEase.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="shapeAppearance">@style/ShapeAppearance.MindEase.Pill</item>
        <item name="chipBackgroundColor">?attr/colorSecondaryContainer</item>
        <item name="chipStrokeColor">?attr/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">?attr/colorOnSecondaryContainer</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="Widget.MindEase.Chip.Filter" parent="Widget.MindEase.Chip">
        <item name="chipBackgroundColor">@color/chip_filter_background</item>
        <item name="chipStrokeColor">@color/chip_filter_stroke</item>
        <item name="android:textColor">@color/chip_filter_text</item>
        <item name="rippleColor">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Widget.MindEase.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.MindEase.BottomNavigation.ActiveIndicator</item>
        <item name="itemIconTint">@color/bottom_nav_item_colors</item>
        <item name="itemTextColor">@color/bottom_nav_item_colors</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.MindEase.BottomNav</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.MindEase.BottomNav</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.MindEase.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MindEase.Pill</item>
    </style>

    <style name="ShapeAppearance.MindEase.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearance.MindEase.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>

    <style name="ShapeAppearance.MindEase.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearance.MindEase.Pill" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">999dp</item>
    </style>

    <style name="TextAppearance.MindEase.BottomNav" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
