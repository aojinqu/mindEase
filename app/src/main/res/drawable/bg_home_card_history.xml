<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:startColor="#F5F3FF"
                android:centerColor="#EEF3FF"
                android:endColor="#E7EEFF" />
            <stroke
                android:width="1dp"
                android:color="#85FFFFFF" />
        </shape>
    </item>

    <item
        android:top="-18dp"
        android:right="-18dp">
        <shape android:shape="oval">
            <size
                android:width="180dp"
                android:height="110dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="90dp"
                android:centerColor="#2CFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
