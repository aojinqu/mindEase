<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_cloud_surface" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <item
        android:left="-30dp"
        android:top="-26dp">
        <shape android:shape="oval">
            <size
                android:width="180dp"
                android:height="160dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="90dp"
                android:centerColor="#42A8ECD9"
                android:endColor="#00A8ECD9" />
        </shape>
    </item>

    <item
        android:right="-34dp"
        android:bottom="-22dp">
        <shape android:shape="oval">
            <size
                android:width="188dp"
                android:height="170dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="96dp"
                android:centerColor="#38A4B1F6"
                android:endColor="#00A4B1F6" />
        </shape>
    </item>
</layer-list>
