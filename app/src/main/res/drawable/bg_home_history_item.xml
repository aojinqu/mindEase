<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="0"
                android:startColor="#E6FFFFFF"
                android:endColor="#CCF6F4FF" />
            <stroke
                android:width="1dp"
                android:color="#6FFFFFFF" />
        </shape>
    </item>

    <item
        android:right="-20dp"
        android:top="-10dp">
        <shape android:shape="oval">
            <size
                android:width="140dp"
                android:height="84dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="72dp"
                android:centerColor="#24FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
