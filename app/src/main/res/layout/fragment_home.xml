<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_sky"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="26dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tv_home_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_greeting"
            android:textAppearance="@style/TextAppearance.MindEase.HomeHeroTitle" />

        <!-- <TextView
            android:id="@+id/tv_home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/home_subtitle"
            android:textAppearance="@style/TextAppearance.MindEase.HomeHeroSubtitle" /> -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="34dp"
            app:cardElevation="6dp"
            app:strokeColor="#73FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_card_primary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tv_home_mood_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="&#x1F60C;"
                        android:textSize="84sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1.25"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_home_mood_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm"
                        android:textAppearance="@style/TextAppearance.MindEase.HomeSectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_home_progress_track"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/view_home_progress_fill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="56"
                            android:background="@drawable/bg_home_progress_fill" />

                        <View
                            android:id="@+id/view_home_progress_rest"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="44" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_home_mood_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Take a breath. You're doing okay."
                        android:textAppearance="@style/TextAppearance.MindEase.HomeBodyLarge" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_quick_checkin"
                        style="@style/Widget.MindEase.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_home_button_primary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="64dp"
                        android:text="@string/home_log_feeling"
                        android:textAppearance="@style/TextAppearance.MindEase.HomeButton"
                        app:cornerRadius="32dp"
                        app:iconPadding="0dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.MindEase.Pill" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_agent_entry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="5dp"
            app:strokeColor="#73FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_card_chat"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_home_chat_orb">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#x1F97A;"
                        android:textSize="20sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/home_chat_title"
                        android:textAppearance="@style/TextAppearance.MindEase.HomeChatTitle" />

                    <!-- <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_chat_subtitle"
                        android:textAppearance="@style/TextAppearance.MindEase.HomeCardBodySoft" /> -->
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_agent"
                    style="@style/Widget.MindEase.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_home_button_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="92dp"
                    android:text="@string/home_chat_cta"
                    android:textAppearance="@style/TextAppearance.MindEase.HomeButtonSmall"
                    app:cornerRadius="26dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MindEase.Pill" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mood_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="30dp"
            app:cardElevation="5dp"
            app:strokeColor="#73FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_card_history"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mood History"
                    android:textAppearance="@style/TextAppearance.MindEase.HomeSectionTitle" />

                <LinearLayout
                    android:id="@+id/row_history_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_home_history_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tv_history_emoji_1"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_home_history_emoji"
                        android:gravity="center"
                        android:text="&#x1F60C;"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_history_title_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calm"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardTitle" />

                        <TextView
                            android:id="@+id/tv_history_meta_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="20 minutes ago • study, exam"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardBodySoft" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="›"
                        android:textColor="#9FA8D8"
                        android:textSize="34sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_history_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_home_history_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tv_history_emoji_2"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_home_history_emoji"
                        android:gravity="center"
                        android:text="&#x1F60A;"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_history_title_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Happy"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardTitle" />

                        <TextView
                            android:id="@+id/tv_history_meta_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Yesterday evening • friends"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardBodySoft" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="›"
                        android:textColor="#9FA8D8"
                        android:textSize="34sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_history_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_home_history_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tv_history_emoji_3"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_home_history_emoji"
                        android:gravity="center"
                        android:text="&#x1F630;"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_history_title_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anxious"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardTitle" />

                        <TextView
                            android:id="@+id/tv_history_meta_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="April 20 • exam, stress"
                            android:textAppearance="@style/TextAppearance.MindEase.HomeCardBodySoft" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="›"
                        android:textColor="#9FA8D8"
                        android:textSize="34sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
