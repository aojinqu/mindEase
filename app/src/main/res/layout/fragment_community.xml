<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shared support, gently moderated"
            android:textAppearance="@style/TextAppearance.MindEase.Label" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anonymous Community"
            android:textAppearance="@style/TextAppearance.MindEase.Display" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_community_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_all"
                style="@style/Widget.MindEase.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:checkable="true"
                android:text="All" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_anxious"
                style="@style/Widget.MindEase.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Anxious" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_stress"
                style="@style/Widget.MindEase.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Stress" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_sleep"
                style="@style/Widget.MindEase.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Sleep" />
        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_post"
                style="@style/Widget.MindEase.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create Post" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_detail"
                style="@style/Widget.MindEase.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Open Detail" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_community_primary"
            style="@style/Widget.MindEase.Card.Highlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_community_primary_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#exam #anxious"
                    android:textAppearance="@style/TextAppearance.MindEase.Label" />

                <TextView
                    android:id="@+id/tv_community_primary_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="I feel pressure before finals, anyone has simple ways to calm down?"
                    android:textAppearance="@style/TextAppearance.MindEase.Body" />

                <TextView
                    android:id="@+id/tv_community_primary_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="support 24 · like 17"
                    android:textAppearance="@style/TextAppearance.MindEase.Supporting" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ListView
            android:id="@+id/lv_community_posts"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/transparent"
            android:dividerHeight="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
