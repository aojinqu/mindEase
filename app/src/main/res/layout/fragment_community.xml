<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY"
            android:textAppearance="@style/TextAppearance.MindEase.Label" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Anonymous Community"
            android:textAppearance="@style/TextAppearance.MindEase.Display"
            android:textColor="?attr/colorOnBackground"
            android:textSize="34sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MindEase.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_community_hot"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Hot Topics"
                        android:textAppearance="@style/TextAppearance.MindEase.Body"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_community_hot_topic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Stress"
                        android:textAppearance="@style/TextAppearance.MindEase.Headline"
                        android:textSize="18sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="14dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MindEase.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_community_message"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Active Now"
                        android:textAppearance="@style/TextAppearance.MindEase.Body"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_community_active_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="4 Posts"
                        android:textAppearance="@style/TextAppearance.MindEase.Headline"
                        android:textSize="18sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_community_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true" />
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_post"
            style="@style/Widget.MindEase.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Share Anonymously"
            android:textAppearance="@style/TextAppearance.MindEase.HomeButton"
            app:cornerRadius="26dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_community_primary"
            style="@style/Widget.MindEase.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_community_primary_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="CalmWhale610"
                        android:textAppearance="@style/TextAppearance.MindEase.Headline"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/tv_community_primary_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="04-12 06:34"
                        android:textAppearance="@style/TextAppearance.MindEase.Supporting"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_community_primary_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="#STRESS"
                    android:textAppearance="@style/TextAppearance.MindEase.Label"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_community_primary_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="nonono"
                    android:textAppearance="@style/TextAppearance.MindEase.Body"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layout_primary_like"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_community_action_pill"
                        android:backgroundTint="?attr/colorPrimary"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageButton
                            android:id="@+id/btn_primary_like"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Like post"
                            android:padding="8dp"
                            android:src="@drawable/ic_community_heart_outline"
                            app:tint="?attr/colorOnPrimary" />

                        <TextView
                            android:id="@+id/tv_community_primary_like"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="1"
                            android:textAppearance="@style/TextAppearance.MindEase.Title"
                            android:textColor="?attr/colorOnPrimary" />
                    </LinearLayout>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:id="@+id/btn_primary_comment"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_community_action_pill"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_community_comment"
                            app:tint="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tv_community_primary_comment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="1"
                            android:textAppearance="@style/TextAppearance.MindEase.Title"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_recent_voices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Recent Voices"
            android:textAppearance="@style/TextAppearance.MindEase.Headline"
            android:textSize="20sp" />

        <ListView
            android:id="@+id/lv_community_posts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent"
            android:divider="@android:color/transparent"
            android:dividerHeight="12dp"
            android:nestedScrollingEnabled="true"
            android:transcriptMode="disabled" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
