<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_onboarding"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A softer space for daily check-ins"
            android:textAppearance="@style/TextAppearance.MindEase.Label" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Welcome to MindEase"
            android:textAppearance="@style/TextAppearance.MindEase.Display" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_wellness_highlight"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Build a steadier rhythm"
                android:textAppearance="@style/TextAppearance.MindEase.Headline" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Track emotional patterns, notice what helps, and keep support close without pressure."
                android:textAppearance="@style/TextAppearance.MindEase.Body" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MindEase.Card.Warm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What you can do here"
                    android:textAppearance="@style/TextAppearance.MindEase.Title" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="1. Quick mood check-ins in under a minute&#10;&#10;2. Gentle trend summaries for the week&#10;&#10;3. Anonymous, low-pressure community support"
                    android:textAppearance="@style/TextAppearance.MindEase.Body" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="MindEase is a non-medical emotional support tool."
            android:textAppearance="@style/TextAppearance.MindEase.Supporting" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            style="@style/Widget.MindEase.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Continue" />
    </LinearLayout>

</ScrollView>
