<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.MindEase.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_item_comment_author"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Anon"
                android:textAppearance="@style/TextAppearance.MindEase.Headline"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_item_comment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04-12 08:15"
                android:textAppearance="@style/TextAppearance.MindEase.Supporting"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_item_comment_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="COMMENT"
            android:textAppearance="@style/TextAppearance.MindEase.Label"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_item_comment_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="This is a comment"
            android:textAppearance="@style/TextAppearance.MindEase.Body"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/layout_item_comment_like"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_community_action_pill"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageButton
                    android:id="@+id/btn_item_comment_like"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Like comment"
                    android:padding="8dp"
                    android:src="@drawable/ic_community_heart_outline"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_item_comment_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.MindEase.Title"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_item_comment_reply"
                style="@style/Widget.MindEase.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:maxLines="1"
                android:textSize="12sp"
                android:text="Reply" />

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_item_comment_delete"
                style="@style/Widget.MindEase.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:maxLines="1"
                android:textSize="12sp"
                android:text="Delete" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
