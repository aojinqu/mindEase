<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.MindEase.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_item_post_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="PeacefulSnail"
                android:textAppearance="@style/TextAppearance.MindEase.Headline"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tv_item_post_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04-12 08:15"
                android:textAppearance="@style/TextAppearance.MindEase.Supporting"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_item_post_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="#ANXIETY"
            android:textAppearance="@style/TextAppearance.MindEase.Label"
            android:textColor="?attr/colorPrimary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_item_post_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:maxLines="4"
            android:text="Feeling overwhelmed today. Anyone else?"
            android:textAppearance="@style/TextAppearance.MindEase.Body"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/layout_item_post_like"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_community_action_pill"
                android:backgroundTint="?attr/colorPrimary"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageButton
                    android:id="@+id/btn_item_post_like"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Like post"
                    android:padding="8dp"
                    android:src="@drawable/ic_community_heart_outline"
                    app:tint="?attr/colorOnPrimary" />

                <TextView
                    android:id="@+id/tv_item_post_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="3"
                    android:textAppearance="@style/TextAppearance.MindEase.Title"
                    android:textColor="?attr/colorOnPrimary" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/btn_item_post_comment"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_community_action_pill"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_community_comment"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_item_post_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="2"
                    android:textAppearance="@style/TextAppearance.MindEase.Title"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
